# Legacy public review form link, if an external form is ever needed.
NEXT_PUBLIC_REVIEW_FORM_URL=

# Optional on-site review form endpoint. If blank, the on-site review form opens a prefilled email.
NEXT_PUBLIC_REVIEW_FORMSPREE_ENDPOINT=

# Optional Google Analytics 4 Measurement ID. Example format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Optional contact form endpoint.
